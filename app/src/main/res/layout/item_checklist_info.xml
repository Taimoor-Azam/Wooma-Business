<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/_12sdp"
    android:background="@drawable/bg_edittext"
    android:orientation="vertical"
    android:padding="@dimen/_16sdp">

    <TextView
        android:id="@+id/tvInfoQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/sofiasans_semibold"
        android:text="@string/question"
        android:textColor="@color/lbls_color"
        android:textSize="@dimen/_12ssp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="@drawable/bg_edittext">

        <EditText
            android:id="@+id/etInfoAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/ivSaveTick"
            android:background="@android:color/transparent"
            android:fontFamily="@font/sofiasans_regular"
            android:hint="Type answer here..."
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:minLines="1"
            android:padding="@dimen/_10sdp"
            android:scrollHorizontally="false"
            android:textColor="@color/black"
            android:textColorHint="@color/light_grey"
            android:textSize="@dimen/_12ssp" />

        <ImageView
            android:id="@+id/ivSaveTick"
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/_8sdp"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/svg_tick"
            android:visibility="gone" />

    </RelativeLayout>

</LinearLayout>
