<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="@dimen/_14sdp"
    android:paddingTop="@dimen/_12sdp"
    android:paddingEnd="@dimen/_14sdp"
    android:paddingBottom="@dimen/_12sdp">

    <ImageView
        android:id="@+id/ivPriorityIcon"
        android:layout_width="@dimen/_22sdp"
        android:layout_height="@dimen/_22sdp"
        android:contentDescription="Priority icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPriorityTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:fontFamily="@font/sofiasans_bold"
        android:textColor="@color/black"
        android:textSize="@dimen/_13ssp"
        app:layout_constraintEnd_toStartOf="@id/ivCheck"
        app:layout_constraintStart_toEndOf="@id/ivPriorityIcon"
        app:layout_constraintTop_toTopOf="@id/ivPriorityIcon" />

    <TextView
        android:id="@+id/tvPrioritySubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_2sdp"
        android:fontFamily="@font/sofiasans_regular"
        android:textColor="@color/lbls_color"
        android:textSize="@dimen/_11ssp"
        app:layout_constraintEnd_toStartOf="@id/ivCheck"
        app:layout_constraintStart_toEndOf="@id/ivPriorityIcon"
        app:layout_constraintTop_toBottomOf="@id/tvPriorityTitle" />

    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="@dimen/_16sdp"
        android:layout_height="@dimen/_16sdp"
        android:contentDescription="Selected"
        android:src="@drawable/svg_tick"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
